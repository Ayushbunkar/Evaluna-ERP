{
  "name": "evaluna-erp",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.3.6",
      "lucide-react": "^0.575.0",
      "next": "^16.1.6",
      "next-themes": "^0.4.6",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "sonner": "^2.0.7",
      "@trpc/server": "^11.10.0",
      "@trpc/client": "^11.10.0",
      "better-auth": "^1.4.20",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.2.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:www": "turbo -F @evaluna/www dev",
    "db:push": "turbo -F @evaluna/db db:push",
    "db:studio": "turbo -F @evaluna/db db:studio",
    "db:generate": "turbo -F @evaluna/db db:generate",
    "db:migrate": "turbo -F @evaluna/db db:migrate",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@evaluna/env": "workspace:*",
    "@tanstack/zod-form-adapter": "^0.42.1",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0",
    "playwright": "^1.61.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@evaluna/config": "workspace:*",
    "@types/node": "^26.1.1",
    "drizzle-kit": "^0.31.10",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.5"
}
